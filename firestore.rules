rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone signed in through the app can read, add and update
    // (staff sign tools out/in, request supplies, count stock).
    // Only the ADMIN (email/password sign-in) can DELETE — staff use
    // anonymous sign-in, so they can never wipe tools, stock or history.
    match /{document=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider == 'password';
    }
  }
}
