rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Small trusted crew: anyone signed in through the KelMar app (anonymous auth)
    // can read/write. Locks out random internet traffic. Can be tightened later
    // with named accounts / PINs if needed.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
