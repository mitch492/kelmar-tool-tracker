{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [{ "key": "Permissions-Policy", "value": "camera=(self)" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
